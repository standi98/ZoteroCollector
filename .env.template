# ─── Zotero Extract Configuration ────────────────────────────────────────────

# Path to your Zotero SQLite database.
# Default locations by OS:
#   Windows : C:/Users/<you>/Zotero/zotero.sqlite
#   macOS   : /Users/<you>/Zotero/zotero.sqlite
#   Linux   : /home/<you>/Zotero/zotero.sqlite
# Leave blank to use the default ~/Zotero/zotero.sqlite
ZOTERO_DB_PATH=PATH_TO_YOUR_ZOTERO_SQLITE